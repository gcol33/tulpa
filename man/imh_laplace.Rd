  X <- cbind(1, x)

  lap <- tulpa_laplace(y, n_trials = rep(1L, n), X = X,
                       family = "binomial")

  log_post <- function(beta) {
    eta <- as.numeric(X \%*\% beta)
    sum(y * eta - log1p(exp(eta))) +
