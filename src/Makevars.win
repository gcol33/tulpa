CXX_STD = CXX17
PKG_CXXFLAGS = $(SHLIB_OPENMP_CXXFLAGS) -I../inst/include -Wa,-mbig-obj
PKG_LIBS = $(SHLIB_OPENMP_CXXFLAGS) $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS)

# At -O2 the EM driver's template/inline instantiation (Eigen + the nmix_kernel.h
# inlines + std) overflows the COFF COMDAT section table even with -Wa,-mbig-obj
# (section-name truncation -> "file format not recognized" at link on rtools45).
# The per-species marginal it calls is out-of-line at -O2 in
# nmix_community_oracle.cpp, so building only this driver at -O1 keeps the object
# within section limits at no runtime cost.
nmix_community_em.o: CXXFLAGS := $(patsubst -O2,-O1,$(CXXFLAGS))
